{
  "name": "sangol-backend",
  "version": "1.0.0",
  "description": "산골 B2B 발주 시스템 백엔드 API",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "tsx src/database/migrations/run.ts",
    "seed:dev-admin": "tsx src/scripts/seedDevAdmin.ts",
    "seed:cms-content": "tsx src/scripts/seedCmsContent.ts",
    "seed:init": "tsx src/scripts/bootstrapCmsAssetsFromSeed.ts && tsx src/scripts/seedCmsContent.ts",
    "fix:cms-media-names": "tsx src/scripts/fixCmsMediaOriginalNames.ts",
    "fix:cms-media-urls": "tsx src/scripts/fixCmsMediaUrls.ts",
    "docker:postgres:up": "bash scripts/docker-postgres.sh up -d",
    "docker:postgres:down": "bash scripts/docker-postgres.sh down",
    "docker:postgres:reset": "bash scripts/docker-postgres.sh down -v && bash scripts/docker-postgres.sh up -d"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.22.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.20.0",
    "@types/swagger-ui-express": "^4.1.8",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  }
}
